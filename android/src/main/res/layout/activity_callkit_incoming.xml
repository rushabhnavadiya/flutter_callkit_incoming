<?xml version="1.0" encoding="utf-8"?>
<!--
    File: android/src/main/res/layout/activity_callkit_incoming.xml
    (custom redesigned portrait layout matching exact mockups & vertical spacing parameters)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Red Glow Background Layer -->
    <View
        android:id="@+id/bg_glow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_critical_alert_gradient" />

    <ScrollView
        android:id="@+id/root_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/transparent"
        android:scrollbars="none">

    <LinearLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="64dp"
        android:paddingBottom="36dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- 1. Badge Row ("TAPP ALERT · just now") -->
        <LinearLayout
            android:id="@+id/badge_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/alert_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="7dp"
                android:background="@drawable/dot_red" />

            <TextView
                android:id="@+id/tv_alert_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAPP ALERT"
                android:textColor="#FF1744"
                android:textSize="12sp"
                android:letterSpacing="0.25"
                android:fontFamily="@font/baloo2_bold" />

            <TextView
                android:id="@+id/tv_alert_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="·  just now"
                android:textColor="#6E6E6E"
                android:textSize="12sp"
                android:fontFamily="@font/baloo2_regular"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 2. Group Pill -->
        <LinearLayout
            android:id="@+id/group_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_pill_translucent"
            android:paddingStart="7dp"
            android:paddingEnd="16dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_group_avatar"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:text="SM"
                android:textColor="#00E676"
                android:textSize="11sp"
                android:fontFamily="@font/baloo2_bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/tv_group_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Stoke Market"
                android:textColor="#B0B0B0"
                android:textSize="13.5sp"
                android:fontFamily="@font/baloo2_semibold" />
        </LinearLayout>

        <!-- 3. Pulsing Concentric Ring Icon -->
        <FrameLayout
            android:id="@+id/ring_icon_wrap"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="0dp">

            <!-- Outer Ring 2 (12.5% opacity stroke) -->
            <View
                android:id="@+id/pulse_ring_outer"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ring_outer" />

            <!-- Middle Ring 1 (30% opacity stroke) -->
            <View
                android:id="@+id/pulse_ring_middle"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ring_middle" />

            <!-- Innermost Circle with Bell Icon (12% opacity fill + solid red stroke) -->
            <RelativeLayout
                android:id="@+id/pulse_ring_inner"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ring_icon_circle">

                <ImageView
                    android:id="@+id/iv_bell_icon"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_bell_critical"
                    android:tint="#FF1744" />
            </RelativeLayout>
        </FrameLayout>

        <!-- 4. Main Message ("BUY NOW") -->
        <TextView
            android:id="@+id/tv_main_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BUY NOW"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:gravity="center"
            android:fontFamily="@font/baloo2_bold"
            android:letterSpacing="-0.024"
            android:shadowColor="#73FF1744"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12"
            android:layout_marginBottom="4dp" />

        <!-- 5. Sub Message -->
        <TextView
            android:id="@+id/tv_sub_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ONGC breakout confirmed.\nMarket momentum detected."
            android:textColor="#B0B0B0"
            android:textSize="16sp"
            android:fontFamily="@font/baloo2_regular"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 6. Priority Chip ("CRITICAL") -->
        <LinearLayout
            android:id="@+id/priority_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_priority_chip_red"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:layout_marginBottom="0dp">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_bolt"
                android:tint="#FF1744"
                android:layout_marginEnd="7dp" />

            <TextView
                android:id="@+id/tv_priority_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CRITICAL"
                android:textColor="#FF1744"
                android:textSize="12.5sp"
                android:fontFamily="@font/baloo2_bold"
                android:letterSpacing="0.12" />
        </LinearLayout>

        <!-- Flexible spacer to push the sender footer and buttons to the bottom of the screen -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 7. Sender Footer -->
        <TextView
            android:id="@+id/tv_sender_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sent by Rushal Patel (Captain)"
            android:textColor="#6E6E6E"
            android:textSize="13sp"
            android:fontFamily="@font/baloo2_regular"
            android:gravity="center" />

        <!-- 8. Primary Action: View Details (height 56dp, corner radius 28dp) -->
        <Button
            android:id="@+id/btn_view_details"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="2dp"
            android:text="View Details"
            android:textAllCaps="false"
            android:textColor="#0A0A0A"
            android:textSize="16sp"
            android:fontFamily="@font/baloo2_bold"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="28dp" />

        <!-- 9. Secondary Action: Ignore (height 52dp, corner radius 26dp) -->
        <Button
            android:id="@+id/btn_ignore"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Ignore"
            android:layout_marginBottom="8dp"
            android:textAllCaps="false"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:fontFamily="@font/baloo2_semibold"
            android:backgroundTint="#0DFFFFFF"
            app:cornerRadius="28dp"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1dp" />

    </LinearLayout>
    </ScrollView>

    <!-- Close Button (X) in Top-Right Corner -->
    <ImageButton
        android:id="@+id/btn_close"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_close_circle"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close"
        android:tint="#FFFFFF"
        android:contentDescription="Close" />

</FrameLayout>