<?xml version="1.0" encoding="utf-8"?>
<!-- Compact Incoming Notification -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingTop="4dp"
    android:paddingEnd="8dp"
    android:paddingBottom="2dp">

    <!-- ================= CONTENT ================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <!-- Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Group Name -->
            <TextView
                android:id="@+id/tvNameCaller"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Alert Title -->
            <TextView
                android:id="@+id/tvNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textAppearance="@style/TextAppearance.Compat.Notification.Line2"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_avatar"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_group_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_circle"
                android:fontFamily="@font/baloo2_bold"
                android:gravity="center"
                android:textColor="#00E676"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="visible" />

        </FrameLayout>

    </LinearLayout>

    <!-- ================= ACTIONS ================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <!-- Ignore -->
        <LinearLayout
            android:id="@+id/llDecline"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDecline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_decline"
                android:textAllCaps="false"
                android:textAppearance="@style/TextAppearance.Compat.Notification"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Vertical Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:layout_gravity="center_vertical"
            android:background="#18FFFFFF" />

        <!-- View Details -->
        <LinearLayout
            android:id="@+id/llAccept"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:id="@+id/tvAccept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_accept"
                android:textAllCaps="false"
                android:textAppearance="@style/TextAppearance.Compat.Notification"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>