<?xml version="1.0" encoding="utf-8"?>
<!-- File: android/src/main/res/drawable/bg_critical_alert_gradient.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Top Glow (Radial Gradient at the top center, fading out around the title area) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="350dp"
                android:centerX="0.5"
                android:centerY="0.0"
                android:startColor="#66FF1744"
                android:centerColor="#1AFF1744"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Bottom Glow (Radial Gradient at the bottom center, forming the soft bottom aura) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="350dp"
                android:centerX="0.5"
                android:centerY="1.0"
                android:startColor="#80FF1744"
                android:centerColor="#1AFF1744"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
